{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StoryPlan",
  "description": "Seedance Pro 故事规划输出 Schema v5.1-Peng",
  "type": "object",
  "required": ["title", "outline", "segments", "metadata"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "description": "短片标题" },
    "outline": { "type": "string", "minLength": 1, "description": "故事大纲" },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "species": { "type": "string" },
          "features": { "type": "array", "items": { "type": "string" } },
          "signature": { "type": "string" },
          "role": { "type": "string", "enum": ["protagonist", "antagonist", "supporting", "narrator"] }
        }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "shots"],
        "properties": {
          "id": { "type": "string", "pattern": "^S\\d+$" },
          "title": { "type": "string" },
          "duration": { "type": "number", "minimum": 1 },
          "shots": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/shot" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["totalDuration", "totalShots"],
      "properties": {
        "totalDuration": { "type": "number", "minimum": 1 },
        "totalShots": { "type": "integer", "minimum": 1 },
        "style": { "type": "string" },
        "type": { "type": "string", "enum": ["action", "educational", "drama", "commercial", "documentary"] },
        "emotionCurve": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 10 }
        }
      }
    }
  },
  "$defs": {
    "shot": {
      "type": "object",
      "required": ["id", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^S\\d+-\\d+$" },
        "description": { "type": "string", "minLength": 1 },
        "duration": { "type": "number", "minimum": 1 },
        "camera": { "type": "string" },
        "characters": { "type": "array", "items": { "type": "string" } },
        "emotion": { "type": "string" },
        "skinTexture": { "type": "string", "description": "皮肤质感描述（仅人类角色）" }
      }
    }
  }