  "diamondLineRules": {
    "maxCount": 3,
    "standards": [
      "多层含义：表面说A，暗里说B，情感里是C",
      "不可替代：删掉这句，整个故事坍塌",
      "声音签名：只有这个异兽在这种时刻会说这句话"
    ],
    "allocation": {
      "act1": {
        "quota": "可选",
        "maxChars": 15,
        "function": "世界观暗示"
      },
      "act2": {
        "quota": "最多2句",
        "maxChars": 10,
        "function": "情感转折催化剂"
      },
      "act3": {
        "quota": "最多1句",
        "maxChars": 8,
        "function": "余震引信，或零台词"
      }
    }
  },
  "silenceRules": {
    "lastSegmentMinSeconds": 8,
    "functions": [
      "情感放大器：静默中，观众的心跳填补声音空缺",
      "意义发生器：没有台词强制解释，观众自己创造意义",
      "余韵容器：故事结束后，静默在观众心中继续"
    ]
  },
  "coreImageryRules": {
    "definition": "一个意象在最后10秒静默绽放，承担角色弧光+主题点题+情感余韵",
    "requirements": [
      "前50秒必须预埋线索（种子）",
      "最后10秒静默绽放（开花）",
      "功能三重：角色弧光完成 + 主题点题 + 情感余韵"
    ],
    "prePlantingChecklist": [
      "第一幕是否有种子植入？",
      "第二幕是否有线索强化？",
      "第三幕是否有静默绽放？"
    ]
  },
  "sensoryNarrativePrinciples": [
    {
      "name": "感知层",
      "rule": "建立异化世界观——异兽感知到的世界是完全不同的宇宙",
      "example": "不是'一个孩子走进峡谷'，而是'一个频率穿透地脉，轻得像谎言，却真实得像记忆'"
    },
    {
      "name": "情绪层",
      "rule": "展示而非告知——情绪 = 身体部位的非正常现象 + 异兽特有的感知语言",
      "example": "不是'我很孤独'，而是'战魂的回声在峡谷中 bounced back，没有人接住'"
    },
    {
      "name": "意志层",
      "rule": "意象即台词——一个核心意象在最后10秒出现，承担所有叙事功能",
      "example": "刑天的核心意象：火种被另一只手托住"
    }
  ]
}