{
  "name": "@lark-apaas/openclaw-extension-miaoda",
  "version": "1.0.21",
  "description": "妙搭 OpenClaw 插件",
  "type": "module",
  "scripts": {
    "build:slardar": "pnpm --filter @lark-apaas/openclaw-slardar build",
    "build": "pnpm build:slardar && tsdown",
    "build:dev": "pnpm build:slardar && MINIFY=false tsdown",
    "prune": "npm install --omit=dev",
    "test": "vitest run",
    "test:cov": "vitest --coverage",
    "ci": "npm run test",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.mjs"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-logs": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@lark-apaas/http-client": "^0.1.5",
    "@vitest/coverage-v8": "^4.1.1",
    "openclaw": "^2026.3.2",
    "tsdown": "^0.21.0",
    "vitest": "^4.0.18"
  }
}
