# Stormaxe AI Video System — Environment Variables
# Copy this file to .env and fill in your credentials

# ==========================================
# Required: Generative AI API Keys
# ==========================================

# ByteDance ARK API (primary video generation)
# Get your key at: https://console.volcengine.com/ark
ARK_API_KEY=ark-your-ark-key-here

# OR: OpenAI API (alternative)
OPENAI_API_KEY=sk-your-openai-key-here

# OR: Minimax API
MINIMAX_API_KEY=your-minimax-key-here

# ==========================================
# Optional: Cloud Storage
# ==========================================

# Volcengine TOS (for storing generated media)
VOLCENGINE_ACCESS_KEY=your-access-key
VOLCENGINE_SECRET_KEY=your-secret-key
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_BUCKET=your-bucket-name

# ==========================================
# Optional: Service Endpoints
# ==========================================

# ByteDance Seedance endpoint
SEEDANCE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# OpenAI endpoint (if using proxy)
OPENAI_ENDPOINT=https://api.openai.com/v1

# ==========================================
# Optional: Feature Flags
# ==========================================

# Pre-production mode (skip render)
PRE_PRODUCTION_MODE=true

# Video type (action/drama/educational/commercial/documentary)
VIDEO_TYPE=drama

# Default language
DEFAULT_LANG=zh-CN
